{
  "name": "file-template",
  "displayName": "File Template",
  "description": "Create files from custom templates",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:fileTemplate.createFile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fileTemplate.createFile",
        "title": "Create File from Template",
        "category": "File Template"
      }
    ],
    "configuration": {
      "title": "File Template",
      "properties": {
        "fileTemplate.globalPath": {
          "type": "string",
          "default": "~/.vscode-templates",
          "description": "Path to global templates directory"
        },
        "fileTemplate.author": {
          "type": "string",
          "default": "",
          "description": "Author name for {{author}} variable"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^16.x",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0"
  }
}
